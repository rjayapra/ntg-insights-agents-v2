PROJECT_ENDPOINT=<foundry endpoint url>
# Both agents share the KB MCP connection created by create_knowledge_base.py
MCP_CONNECTION_NAME=ntg-shared-kb-mcp
MCP_SERVER_URL=https://<search-service>.search.windows.net/knowledgebases/ntg-shared-kb/mcp?api-version=2025-11-01-preview
MCP_SERVER_LABEL=ntg_kb
QSP_AGENT_NAME=NTG-QSP-Agent
LESSONPLAN_AGENT_NAME=NTG-LessonPlanning-Agent
MODEL_NAME=gpt-4.1

# --- Knowledge Base (Foundry IQ) provisioning ---
# Required by agent/create_knowledge_base.py
PROJECT_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<foundry-account>/projects/<project-name>
SEARCH_ENDPOINT=https://<search-service>.search.windows.net
SEARCH_INDEX_NAME=<existing-search-index-name>
AOAI_ENDPOINT=https://<foundry-account>.cognitiveservices.azure.com/
AOAI_CHAT_DEPLOYMENT=gpt-4.1
AOAI_CHAT_MODEL=gpt-4.1

# Optional KB tuning
KB_NAME=ntg-shared-kb
KS_NAME=ntg-shared-ks
KB_CONNECTION_NAME=ntg-shared-kb-mcp
KB_REASONING_EFFORT=low
KB_ANSWER_INSTRUCTIONS=Return the top search result and include citations to source documents.
KB_RETRIEVAL_INSTRUCTIONS=

# Optional: AI Search data-plane fallback (use admin key when you only have control-plane Contributor on the Search service)
# Fetch with: az search admin-key show --service-name <search-service> -g <rg> --query primaryKey -o tsv
SEARCH_ADMIN_KEY=
